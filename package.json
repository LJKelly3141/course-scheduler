{
  "name": "chairsdesk",
  "version": "1.3.1",
  "description": "The Chair's Desk - Desktop Application",
  "main": "electron/main.cjs",
  "private": true,
  "scripts": {
    "electron:dev": "electron electron/main.cjs",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && ./venv/bin/pyinstaller course_scheduler.spec --noconfirm",
    "build:backend:win": "cd backend && venv\\Scripts\\pyinstaller course_scheduler.spec --noconfirm",
    "build:app": "npm run build:frontend && npm run build:backend && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "app.chairsdesk",
    "productName": "The Chair's Desk",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "frontend/dist",
        "to": "frontend/dist"
      },
      {
        "from": "backend/dist/course_scheduler",
        "to": "backend"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.education"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "TheChairsDesk-${version}-portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false
    },
    "dmg": {
      "title": "The Chair's Desk",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
